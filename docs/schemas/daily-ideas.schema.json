{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daily Client Content Ideas",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "client_name",
    "generated_for_date",
    "ideas"
  ],
  "properties": {
    "client_name": {
      "type": "string"
    },
    "generated_for_date": {
      "type": "string",
      "description": "ISO date in YYYY-MM-DD format."
    },
    "ideas": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "idea_type",
          "title",
          "hook",
          "angle",
          "recommended_format",
          "target_platform",
          "target_audience",
          "why_it_should_work",
          "why_now",
          "script_outline",
          "cta",
          "confidence_score",
          "source_urls"
        ],
        "properties": {
          "idea_type": {
            "type": "string",
            "enum": [
              "evergreen_human",
              "realtime_event"
            ]
          },
          "title": {
            "type": "string"
          },
          "hook": {
            "type": "string"
          },
          "angle": {
            "type": "string"
          },
          "recommended_format": {
            "type": "string",
            "enum": [
              "short_video",
              "reel",
              "carousel",
              "single_image",
              "thread",
              "text_post",
              "story_sequence"
            ]
          },
          "target_platform": {
            "type": "string",
            "enum": [
              "instagram",
              "tiktok",
              "linkedin",
              "x",
              "facebook",
              "youtube_shorts",
              "multi_platform"
            ]
          },
          "target_audience": {
            "type": "string"
          },
          "why_it_should_work": {
            "type": "string"
          },
          "why_now": {
            "type": "string"
          },
          "script_outline": {
            "type": "array",
            "minItems": 3,
            "maxItems": 8,
            "items": {
              "type": "string"
            }
          },
          "cta": {
            "type": "string"
          },
          "confidence_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "source_urls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "risk_flags": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "religious_sensitivity",
                "legal_risk",
                "brand_misalignment",
                "stale_trend",
                "low_confidence"
              ]
            }
          },
          "expires_at": {
            "type": "string",
            "description": "Optional ISO timestamp for real-time ideas."
          }
        }
      }
    }
  }
}
